# OAuth2 Client Credentials (preferred — basic auth is being deprecated by OpenSky)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
OPENSKY_TOKEN_URL=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token

# Legacy basic auth fallback
OPENSKY_USERNAME=
OPENSKY_PASSWORD=
OPENSKY_BBOX_MIN_LAT=24.0
OPENSKY_BBOX_MAX_LAT=50.0
OPENSKY_BBOX_MIN_LON=-125.0
OPENSKY_BBOX_MAX_LON=-66.0
POLL_INTERVAL_SECONDS=10
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW=raw-flights
POSTGRES_HOST=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=skystream
POSTGRES_DSN=postgresql://postgres:postgres@postgres:5432/skystream
POSTGRES_JDBC_URL=jdbc:postgresql://postgres:5432/skystream
SPARK_MASTER=local[*]
REDIS_URL=redis://redis:6379
WS_BROADCAST_INTERVAL_MS=5000
VITE_WS_URL=ws://localhost:8000/ws
MAPLIBRE_STYLE_URL=https://tiles.openfreemap.org/styles/liberty
